# ==========================================
# 环境变量配置示例
# ==========================================
# 这是一个示例文件，请勿在生产环境中使用这些默认值。
#
# 在本地开发 (Cloudflare Pages/Workers):
# 1. 您可以将此文件重命名/复制为 `.dev.vars` (推荐) 或 `.env`。
# 2. 修改其中的值为您的真实密钥。
# 3. 运行 `npm run dev` 或 `npx wrangler pages dev` 时会自动加载。
#
# 在生产环境:
# 请在 Cloudflare Dashboard -> Settings -> Variables and Secrets 中配置这些变量。

# [必需] Better Auth 密钥 (必须是随机且安全的字符串)
# 生成命令: openssl rand -base64 32
BETTER_AUTH_SECRET="development_secret_key_1234567890"

# [必需] 应用的基础 URL (本地开发通常是 http://localhost:3000)
BETTER_AUTH_URL="http://localhost:3000"

# [必需] Stripe 支付相关
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# [必需] Resend 邮件服务
RESEND_API_KEY="re_..."

# ==========================================
# Cloudflare D1 & R2 配置说明 (非环境变量)
# ==========================================
# 这些配置项通常在 wrangler.toml 文件中直接设置:

# [[d1_databases]]
# binding = "DB"
# database_name = "my-d1-db"
# database_id = "xxxx-xxxx-xxxx-xxxx" <--- 替换为您的 D1 ID

# [[r2_buckets]]
# binding = "BUCKET"
# bucket_name = "my-r2-bucket" <--- 替换为您的 Bucket 名称
